{
  "name": "event-dates-calendar",
  "version": "2.0.0",
  "private": false,
  "description": "A Node.js application to create and manage personalized calendar TXT files by combining events from multiple sources including Israeli holidays, US holidays, birthdays, anniversaries, and recurring tasks with web scraping and automated processing.",
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/event-dates-calendar.git"
  },
  "keywords": [
    "nodejs",
    "javascript",
    "calendar",
    "events",
    "scheduler",
    "tasks",
    "holidays",
    "israeli-calendar",
    "us-holidays",
    "automation",
    "web-scraping",
    "jsdom",
    "birthdays",
    "anniversaries",
    "event-management"
  ],
  "license": "MIT",
  "author": "Or Assayag <orassayag@gmail.com>",
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "type": "module",
  "engines": {
    "node": "^20.0.0"
  },
  "main": "src/scripts/create.script.js",
  "files": [
    "src",
    ".eslintignore",
    ".eslintrc",
    ".gitignore",
    ".jsbeautifyrc",
    ".npmignore",
    "INSTRUCTIONS.md",
    "package-lock.json",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "backup": "node src/scripts/backup.script.js",
    "sand": "node src/tests/sandbox.test.js",
    "scan": "node src/scripts/scan.script.js",
    "start": "node src/scripts/create.script.js",
    "stop": "taskkill -f -im node.exe"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "is-reachable": "^6.1.0",
    "jsdom": "^28.1.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "eslint": "^10.0.2"
  }
}